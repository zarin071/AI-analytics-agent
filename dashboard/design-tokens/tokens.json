{
  "$description": "Design tokens — single source of truth for the dashboard. Consumed as CSS variables (src/styles/tokens.css is generated from this file) and by Storybook. Swap the color ramp to rebrand the whole dashboard.",
  "color": {
    "bg":            { "light": "#F7F7F5", "dark": "#111312" },
    "surface":       { "light": "#FFFFFF", "dark": "#1A1D1B" },
    "surfaceRaised": { "light": "#FFFFFF", "dark": "#222624" },
    "border":        { "light": "#E4E4DF", "dark": "#313633" },
    "text":          { "light": "#1E211F", "dark": "#ECEEEC" },
    "textMuted":     { "light": "#6B7069", "dark": "#9BA19B" },
    "accent":        { "light": "#3A6B5C", "dark": "#6FB59F" },
    "accentSubtle":  { "light": "#E7F0EC", "dark": "#22332D" },
    "positive":      { "light": "#2E7D4F", "dark": "#69C08D" },
    "negative":      { "light": "#B4453A", "dark": "#E58378" },
    "warning":       { "light": "#9A6B15", "dark": "#D9A94E" },
    "chart": {
      "categorical": ["#3A6B5C", "#B4685A", "#5B6FA8", "#9A7B3F", "#7B5BA8", "#4E8A96", "#A85B84", "#6E8B4E"]
    }
  },
  "font": {
    "sans": "'Inter Variable', system-ui, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, monospace",
    "size": { "xs": "12px", "sm": "13px", "md": "14px", "lg": "16px", "xl": "20px", "xxl": "28px" },
    "weight": { "regular": 400, "medium": 500, "semibold": 600 }
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "7": "48px" },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "full": "999px" },
  "shadow": {
    "card": "0 1px 2px rgba(20,24,22,.06), 0 4px 16px rgba(20,24,22,.05)",
    "popover": "0 8px 32px rgba(20,24,22,.16)"
  },
  "motion": { "fast": "120ms ease-out", "base": "200ms ease-out" }
}
