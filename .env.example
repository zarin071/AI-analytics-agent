# ── AI Analytics Agent — environment ─────────────────────────────
# Copy to .env and fill in. Only these values are required.

# Project
ANALYTICS_PROJECT_NAME="My Project"
NODE_ENV=development

# Database (Postgres 14+)
ANALYTICS_DATABASE_URL=postgres://analytics:analytics@localhost:5432/analytics

# Authentication
ANALYTICS_JWT_SECRET=generate-a-long-random-string
ANALYTICS_SECRET_KEYS=sk_local_dev_secret            # comma-separated, server-side
ANALYTICS_PUBLIC_KEYS=pk_local_dev_public            # comma-separated, client SDKs
ANALYTICS_ALLOWED_ORIGINS=http://localhost:3000

# AI provider (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANALYTICS_AI_MODEL=claude-opus-4-8
ANALYTICS_AI_FAST_MODEL=claude-haiku-4-5

# Ports
ANALYTICS_API_PORT=4000
ANALYTICS_DASHBOARD_PORT=3000
