    "./angular": "./dist/adapters/angular.js",
    "./svelte": "./dist/adapters/svelte.js",
    "./react-native": "./dist/adapters/react-native.js",
    "./node": "./dist/adapters/node.js",
    "./express": "./dist/adapters/express.js",
    "./fastify": "./dist/adapters/fastify.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
